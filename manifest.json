{
  "manifest_version": 3,
  "name": "B站视频解析助手",
  "version": "1.0.0",
  "description": "右键复制bv号然后拼接解析链接",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "https://bilibili.com/*",
    "https://*.bilibili.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "视频解析助手",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://bilibili.com/*", "https://*.bilibili.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "options_page": "options.html"
}
